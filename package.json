{
  "name": "firstpass",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "firstpass": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.1.1",
  "files": [
    "dist",
    "plugins",
    "package.json"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepack": "node scripts/build.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package:check": "node scripts/check-global-install.js"
  },
  "dependencies": {
    "acpx": "0.7.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.2",
    "ink": "^7.0.2",
    "js-yaml": "^4.1.1",
    "react": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.14",
    "acp-mock": "^1.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
